# --- dependencies / build ---
node_modules/
dist/
dist-ssr/
*.local
coverage/
.vite/

# --- collector on-disk HTTP cache (regenerable; conditional-GET store) ---
scripts/.cache/

# --- F5 vintage snapshots (local diffable-history cache; not committed) ---
src/data/collected/*/snapshots/

# --- env / secrets (NEVER commit) ---
.env
.env.*
!.env.example

# --- recovery staging (local reference only — large, contains the recovered .env) ---
_recovered/

# --- editor / OS ---
.DS_Store
*.log
.idea/
.vscode/*
!.vscode/extensions.json
*.tsbuildinfo
